# Copy to api/.env.staging (gitignored) for docker-compose staging overrides.
NODE_ENV=staging
PORT=3001
LOG_LEVEL=info
PORTAL_ORIGIN=https://staging.example.com

DATABASE_URL=postgresql://aihub:CHANGE_ME@postgres:5432/aihub_staging
REDIS_URL=redis://redis:6379

VAULT_ADDR=https://vault.staging.example.com:8200
VAULT_ROLE_ID=
VAULT_SECRET_ID=

KEYCLOAK_URL=https://auth.staging.example.com
KEYCLOAK_REALM=aihub

LITELLM_URL=http://litellm:4000
LITELLM_MASTER_KEY=
