# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
PORTAL_ORIGIN=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://aihub:aihub_dev_secret@localhost:5432/aihub_dev

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── HashiCorp Vault ───────────────────────────────────────────────────────────
VAULT_ADDR=http://localhost:8200
# Dev mode: use root token. Production: comment out VAULT_TOKEN, use AppRole below.
VAULT_TOKEN=aihub-dev-root-token
VAULT_ROLE_ID=
VAULT_SECRET_ID=

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=aihub

# ── LiteLLM ───────────────────────────────────────────────────────────────────
LITELLM_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-litellm-dev-master

# ── AWS CloudWatch (Phase 3+) ─────────────────────────────────────────────────
# AWS_REGION=ap-southeast-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_CLOUDWATCH_LOG_GROUP=/aihub/api
