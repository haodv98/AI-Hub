{
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/aihub/app-info.log",
            "log_group_name": "/aihub/app/info",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 90
          },
          {
            "file_path": "/var/log/aihub/app-error.log",
            "log_group_name": "/aihub/app/error",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 365
          },
          {
            "file_path": "/var/log/aihub/audit.log",
            "log_group_name": "/aihub/audit",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 730
          }
        ]
      }
    }
  }
}
