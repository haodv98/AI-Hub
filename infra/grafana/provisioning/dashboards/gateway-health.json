{
  "id": null,
  "uid": "aihub-gateway-health",
  "title": "AIHub Gateway Health",
  "tags": ["aihub", "gateway"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Requests / min",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(aihub_gateway_requests_total[1m])) * 60",
          "legendFormat": "req/min"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "5xx Error Rate",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(aihub_gateway_requests_total{status=\"error\"}[5m])) / clamp_min(sum(rate(aihub_gateway_requests_total[5m])), 1e-9)",
          "legendFormat": "error rate"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p50/p95/p99 (ms)",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(aihub_gateway_latency_ms_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(aihub_gateway_latency_ms_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(aihub_gateway_latency_ms_bucket[5m])))",
          "legendFormat": "p99"
        }
      ]
    }
  ]
}
