# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://aihub:aihub_dev_secret@localhost:5432/aihub_dev

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── HashiCorp Vault ───────────────────────────────────────────────────────────
VAULT_ADDR=http://localhost:8200
VAULT_ROLE_ID=<vault-approle-role-id>
VAULT_SECRET_ID=<vault-approle-secret-id>
# Dev only — use root token instead of AppRole:
VAULT_TOKEN=aihub-dev-root-token

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=aihub
KEYCLOAK_CLIENT_ID=aihub-admin
KEYCLOAK_CLIENT_SECRET=<keycloak-client-secret>

# ── APISix ────────────────────────────────────────────────────────────────────
APISIX_ADMIN_URL=http://localhost:9180
APISIX_ADMIN_KEY=aihub-apisix-admin-key-dev

# ── LiteLLM ───────────────────────────────────────────────────────────────────
LITELLM_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-litellm-dev-master
LITELLM_DATABASE_URL=

# ── AWS CloudWatch (log export) ───────────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=<aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<aws-secret-access-key>
AWS_CLOUDWATCH_LOG_GROUP=/aihub/app

# ── Slack Integration (Phase 3) ───────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-<your-slack-bot-token>
SLACK_SIGNING_SECRET=<slack-signing-secret>

# ── HR Webhook (Phase 3) ──────────────────────────────────────────────────────
HR_WEBHOOK_SECRET=<hr-webhook-hmac-secret>
HR_MAPPING_JSON=

# ── Backup (Phase 3) ──────────────────────────────────────────────────────────
BACKUP_ENCRYPTION_KEY=<aes-256-cbc-passphrase>
BACKUP_S3_BUCKET=<s3-bucket-name>
NAS_BACKUP_PATH=/mnt/nas/backups/aihub

# ── Reports ───────────────────────────────────────────────────────────────────
EXECUTIVE_REPORT_RECIPIENTS=cto@company.com,cfo@company.com

# ── Internal ──────────────────────────────────────────────────────────────────
INTERNAL_API_SECRET=<secret-for-litellm-callback>
